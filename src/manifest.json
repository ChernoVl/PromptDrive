{
  "manifest_version": 3,
  "name": "PromptDrive",
  "version": "0.1.0",
  "description": "Navigate long chat conversations with timeline, stats, and bookmarks.",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_title": "PromptDrive Controls",
    "default_popup": "popup.html"
  },
  "host_permissions": ["https://chatgpt.com/*"],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
